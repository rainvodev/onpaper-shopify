{% comment %} On Paper — Password (Lumos). Portada "Muy pronto" con el lenguaje de la marca. {% endcomment %}
<section class="op-pass">
  <div class="op-pass_card">
    <p class="op-pass_brand">{{ shop.name }}</p>
    <h1 class="op-pass_title">{{ 'password.title' | t }}</h1>
    {% if shop.password_message != blank %}
      <p class="op-pass_msg">{{ shop.password_message }}</p>
    {% endif %}

    {% form 'storefront_password', class: 'op-pass_form' %}
      {% if form.errors %}
        <div class="op-pass_errors">{{ form.errors | default_errors }}</div>
      {% endif %}
      <label class="op-pass_label" for="password-input">{{ 'password.password' | t }}</label>
      <div class="op-pass_row">
        <input class="op-pass_input" type="password" name="password" id="password-input" autocomplete="current-password">
        <button class="op-pass_submit" type="submit">{{ 'password.enter' | t }}</button>
      </div>
    {% endform %}
  </div>
</section>

{% stylesheet %}
  .op-pass { min-height: 100svh; display: flex; align-items: center; justify-content: center; padding: 2rem; background-color: var(--swatch--light-200, #f5f5ef); color: var(--swatch--brand-500, #5f604e); }
  .op-pass_card { width: min(26rem, 100%); text-align: center; display: flex; flex-direction: column; gap: 1.1rem; }
  .op-pass_brand { font-family: var(--font-label, inherit); text-transform: uppercase; letter-spacing: 0.18em; font-size: 0.72rem; opacity: 0.7; margin: 0; }
  .op-pass_title { font-family: var(--_typography---font--primary-family, serif); font-style: italic; font-weight: 400; font-size: clamp(1.7rem, 5vw, 2.4rem); line-height: 1.15; color: var(--swatch--brand-300, #b0b094); margin: 0; }
  .op-pass_msg { opacity: 0.8; margin: 0; }
  .op-pass_form { display: flex; flex-direction: column; gap: 0.6rem; margin-top: 0.6rem; }
  .op-pass_errors { font-size: 0.85rem; color: #a4472f; }
  .op-pass_label { font-family: var(--font-label, inherit); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.68rem; opacity: 0.7; }
  .op-pass_row { display: flex; gap: 0.5rem; }
  .op-pass_input { flex: 1; font-family: inherit; font-size: 0.95rem; color: inherit; background-color: transparent; border: 0.0625rem solid color-mix(in srgb, currentColor 30%, transparent); border-radius: 2rem; padding: 0.8rem 1.2rem; }
  .op-pass_submit { font-family: var(--font-label, inherit); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.76rem; color: #fff; background-color: var(--swatch--brand-300, #b0b094); border: 0; border-radius: 2rem; padding: 0.8rem 1.5rem; cursor: pointer; transition: background-color 250ms; }
  .op-pass_submit:hover { background-color: var(--swatch--brand-500, #5f604e); }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
