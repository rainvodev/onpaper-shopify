{% comment %} On Paper — Header (Lumos). Barra + mega-menú (Products/Collections con panel a ~50vh,
  lista izquierda + 3 productos derecha que cambian al hover). Others = link simple. Drawer en móvil. {% endcomment %}
{% liquid
  assign is_home = false
  if template.name == 'index'
    assign is_home = true
  endif
  assign groups = 'products,collections' | split: ','
%}
<header class="op-header full-width{% if is_home %} is-overlay u-theme-dark{% endif %}" data-op-header data-reveal="down" data-reveal-load
  style="--reveal-delay: 200ms; --op-feat-ratio: {{ section.settings.feature_ratio | default: '4 / 5' }}" {{ section.shopify_attributes }}>
  <div class="op-header_bar u-container">
    <div class="op-header_layout">
      <a href="{{ routes.root_url }}" class="op-header_logo" aria-label="{{ shop.name }}">
        {% render 'op-logo' %}
      </a>

      <nav class="op-header_nav" aria-label="Principal">
        {%- for g in groups -%}
          <button type="button" class="op-header_link op-header_trigger" data-op-trigger="{{ g }}" aria-expanded="false" aria-controls="op-panel-{{ g }}">
            {%- if g == 'products' -%}{{ section.settings.products_label | default: 'Products' }}{%- else -%}{{ section.settings.collections_label | default: 'Collections' }}{%- endif -%}
          </button>
        {%- endfor -%}
        {%- if section.settings.others_link != blank -%}
          <a href="{{ section.settings.others_link }}" class="op-header_link">{{ section.settings.others_label | default: 'Others' }}</a>
        {%- endif -%}
      </nav>

      <div class="op-header_actions">
        {%- if localization.available_countries.size > 1 -%}
          {%- form 'localization', class: 'op-loc' -%}
            <select name="country_code" class="op-loc_select" aria-label="País / moneda" onchange="this.form.submit()">
              {%- for country in localization.available_countries -%}
                <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>{{ country.currency.iso_code }}</option>
              {%- endfor -%}
            </select>
          {%- endform -%}
        {%- endif -%}
        {%- if localization.available_languages.size > 1 -%}
          {%- form 'localization', class: 'op-loc' -%}
            <select name="language_code" class="op-loc_select" aria-label="Idioma" onchange="this.form.submit()">
              {%- for language in localization.available_languages -%}
                <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>{{ language.iso_code | upcase }}</option>
              {%- endfor -%}
            </select>
          {%- endform -%}
        {%- endif -%}

        <a href="{{ routes.cart_url }}" class="op-header_cart" aria-label="Carrito" data-op-cart-open>
          <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 8h12l-1 12H7L6 8z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></svg>
          <span>Cart (<span data-op-cart-badge>{{ cart.item_count }}</span>)</span>
        </a>

        <button type="button" class="op-header_burger" data-op-burger aria-label="Menú" aria-expanded="false">
          <span class="op-header_burger-box" aria-hidden="true">
            <span class="op-header_burger-bar"></span>
            <span class="op-header_burger-bar"></span>
            <span class="op-header_burger-bar"></span>
          </span>
        </button>
      </div>
    </div>
  </div>

  {%- comment -%} Paneles desktop (dinámicos) {%- endcomment -%}
  {%- liquid
    assign products_col = section.settings.products_collection
    if products_col != blank
      assign product_list = products_col.products
    else
      assign product_list = collections.all.products
    endif
    assign best_col = section.settings.bestsellers_collection
  -%}

  {%- comment -%} PRODUCTS: izquierda = productos; derecha = Best sellers (máx 3) {%- endcomment -%}
  <div class="op-header_panel" id="op-panel-products" data-op-panel="products">
    <div class="op-header_panelgrid u-container">
      <div class="op-header_menucol">
        {%- if section.settings.products_eyebrow != blank -%}
          {%- if section.settings.products_eyebrow_link != blank -%}
            <a class="op-header_eyebrow op-header_eyebrow--link" href="{{ section.settings.products_eyebrow_link }}">{{ section.settings.products_eyebrow }}</a>
          {%- else -%}
            <p class="op-header_eyebrow">{{ section.settings.products_eyebrow }}</p>
          {%- endif -%}
        {%- endif -%}
        <ul class="op-header_menulist">
          {%- for product in product_list limit: 30 -%}
            <li><a class="op-header_menulink" href="{{ product.url }}">{{ product.title }}</a></li>
          {%- else -%}
            {%- if request.design_mode -%}<li class="op-header_empty">Elige la colección que alimenta este dropdown (Panel Products) o publica productos.</li>{%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
      <div class="op-header_feature">
        <div class="op-header_featuregroup is-active">
          {%- if best_col != blank and best_col.products.size > 0 -%}
            {%- for product in best_col.products limit: 3 -%}
              {% render 'op-product-card-mini', product: product %}
            {%- endfor -%}
          {%- elsif request.design_mode -%}
            <p class="op-header_empty">Elige la colección "Best sellers" (Panel Products) para mostrar 3 productos.</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} COLLECTIONS: izquierda = todas las colecciones; derecha = sus 3 primeros productos (swap) {%- endcomment -%}
  <div class="op-header_panel" id="op-panel-collections" data-op-panel="collections">
    <div class="op-header_panelgrid u-container">
      <div class="op-header_menucol">
        {%- if section.settings.collections_eyebrow != blank -%}
          {%- if section.settings.collections_eyebrow_link != blank -%}
            <a class="op-header_eyebrow op-header_eyebrow--link" href="{{ section.settings.collections_eyebrow_link }}">{{ section.settings.collections_eyebrow }}</a>
          {%- else -%}
            <p class="op-header_eyebrow">{{ section.settings.collections_eyebrow }}</p>
          {%- endif -%}
        {%- endif -%}
        <ul class="op-header_menulist">
          {%- for collection in collections -%}
            <li><a class="op-header_menulink{% if forloop.first %} is-active{% endif %}" data-op-item="collections-{{ forloop.index0 }}" href="{{ collection.url }}">{{ collection.title }}</a></li>
          {%- else -%}
            {%- if request.design_mode -%}<li class="op-header_empty">No hay colecciones en la tienda.</li>{%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
      <div class="op-header_feature">
        {%- for collection in collections -%}
          <div class="op-header_featuregroup{% if forloop.first %} is-active{% endif %}" data-op-feature="collections-{{ forloop.index0 }}">
            {%- for product in collection.products limit: 3 -%}
              {% render 'op-product-card-mini', product: product %}
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} Drawer móvil {%- endcomment -%}
  <div class="op-header_drawer" data-op-drawer data-lenis-prevent>
    <div class="op-header_drawerinner u-container">
      <details class="op-header_acc">
        <summary class="op-header_accsum">
          <span>{{ section.settings.products_label | default: 'Products' }}</span>
          <svg class="op-header_chev" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <ul class="op-header_acclist">
          {%- for product in product_list limit: 30 -%}
            <li><a class="op-header_acclink" href="{{ product.url }}">{{ product.title }}</a></li>
          {%- endfor -%}
        </ul>
      </details>
      <details class="op-header_acc">
        <summary class="op-header_accsum">
          <span>{{ section.settings.collections_label | default: 'Collections' }}</span>
          <svg class="op-header_chev" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </summary>
        <ul class="op-header_acclist">
          {%- for collection in collections -%}
            <li><a class="op-header_acclink" href="{{ collection.url }}">{{ collection.title }}</a></li>
          {%- endfor -%}
        </ul>
      </details>
      {%- if section.settings.others_link != blank -%}
        <a class="op-header_accroot" href="{{ section.settings.others_link }}">
          <span>{{ section.settings.others_label | default: 'Others' }}</span>
          <svg class="op-header_chev op-header_chev--go" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      {%- endif -%}

      {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
        <div class="op-header_drawerloc">
          {%- if localization.available_countries.size > 1 -%}
            {%- form 'localization', class: 'op-loc op-loc--drawer' -%}
              <label class="op-header_locrow">
                <span>{{ 'localization.country_label' | t | default: 'País / moneda' }}</span>
                <select name="country_code" class="op-loc_select" aria-label="País / moneda" onchange="this.form.submit()">
                  {%- for country in localization.available_countries -%}
                    <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>{{ country.name }} · {{ country.currency.iso_code }}</option>
                  {%- endfor -%}
                </select>
              </label>
            {%- endform -%}
          {%- endif -%}
          {%- if localization.available_languages.size > 1 -%}
            {%- form 'localization', class: 'op-loc op-loc--drawer' -%}
              <label class="op-header_locrow">
                <span>{{ 'localization.language_label' | t | default: 'Idioma' }}</span>
                <select name="language_code" class="op-loc_select" aria-label="Idioma" onchange="this.form.submit()">
                  {%- for language in localization.available_languages -%}
                    <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>{{ language.endonym_name | capitalize }}</option>
                  {%- endfor -%}
                </select>
              </label>
            {%- endform -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</header>

{% stylesheet %}
  .op-header { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background-color: var(--_theme---background); border-bottom: 0.0625rem solid var(--_theme---border); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1), background-color 0.3s ease, color 0.3s ease; }
  .op-header.is-overlay { background-color: transparent; border-bottom: 0; }
  .op-header.is-overlay.is-scrolled { background-color: #ffffff; color: var(--swatch--brand-500, #5f604e); border-bottom: 0.0625rem solid var(--_theme---border); }
  .op-header.is-hidden { transform: translateY(-100%); }
  .op-header.is-drawer-open.is-hidden { transform: none; }
  @media (prefers-reduced-motion: reduce) { .op-header { transition: background-color 0.3s ease; } .op-header.is-hidden { transform: none; } }
  .op-header.is-menu-open { background-color: var(--swatch--light-200, #f5f5ef); color: var(--swatch--brand-500, #5f604e); border-bottom-color: var(--_theme---border); }
  .op-header_bar { padding-top: var(--_spacing---space--4); padding-bottom: var(--_spacing---space--4); position: relative; z-index: 2; }
  .op-header_layout { display: flex; align-items: center; justify-content: space-between; gap: var(--_spacing---space--5); }
  .op-header_logo { text-decoration: none; color: currentColor; display: inline-flex; align-items: center; }
  .op-logo { display: block; width: 7.5rem; height: auto; color: currentColor; }
  .op-header_nav { display: flex; gap: var(--_spacing---space--6); }
  .op-header_link, .op-loc_select, .op-header_cart, .op-header_accsum, .op-header_accroot, .op-header_eyebrow, .op-header_acclink {
    font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.78rem;
    color: currentColor; text-decoration: none;
  }
  .op-header_trigger { background: none; border: 0; cursor: pointer; padding: 0; position: relative; }
  .op-header_trigger::after { content: ""; position: absolute; left: 0; right: 0; bottom: -0.35rem; height: 0.0625rem; background-color: currentColor; transform: scaleX(0); transform-origin: left; transition: transform 250ms ease; }
  .op-header_trigger:hover::after, .op-header_trigger.is-active::after { transform: scaleX(1); }
  .op-header_actions { display: flex; align-items: center; gap: var(--_spacing---space--4); }
  .op-loc { display: inline-flex; }
  .op-loc_select { background-color: transparent; border: 0; cursor: pointer; color: currentColor; }
  .op-loc_select option { color: #111; }
  .op-header_cart { display: inline-flex; align-items: center; gap: 0.4rem; white-space: nowrap; }
  .op-header_burger { display: none; background: none; border: 0; cursor: pointer; color: currentColor; padding: 0; }
  .op-header_burger-box { position: relative; display: block; width: 1.4rem; height: 0.85rem; }
  .op-header_burger-bar { position: absolute; left: 0; width: 100%; height: 0.09375rem; background-color: currentColor; border-radius: 2px; transition: transform 300ms cubic-bezier(0.4,0,0.2,1), opacity 200ms ease; }
  .op-header_burger-bar:nth-child(1) { top: 0; }
  .op-header_burger-bar:nth-child(2) { top: 50%; margin-top: -0.047rem; }
  .op-header_burger-bar:nth-child(3) { bottom: 0; }
  .op-header_burger[aria-expanded="true"] .op-header_burger-bar:nth-child(1) { transform: translateY(0.38rem) rotate(45deg); }
  .op-header_burger[aria-expanded="true"] .op-header_burger-bar:nth-child(2) { opacity: 0; }
  .op-header_burger[aria-expanded="true"] .op-header_burger-bar:nth-child(3) { transform: translateY(-0.38rem) rotate(-45deg); }
  @media (prefers-reduced-motion: reduce) { .op-header_burger-bar { transition: none; } }

  /* Paneles */
  .op-header_panel { position: absolute; left: 0; right: 0; top: 100%; z-index: 1; background-color: var(--swatch--light-200, #f5f5ef); color: var(--swatch--brand-500, #5f604e); border-bottom: 0.0625rem solid var(--_theme---border); box-shadow: 0 1.5rem 2rem -1.5rem rgba(0,0,0,0.18); min-height: 50svh; max-height: 85vh; overflow-y: auto; visibility: hidden; opacity: 0; transform: translateY(-0.5rem); pointer-events: none; transition: opacity 280ms ease, transform 280ms ease, visibility 0s linear 280ms; }
  .op-header_panel.is-open { visibility: visible; opacity: 1; transform: translateY(0); pointer-events: auto; transition: opacity 280ms ease, transform 280ms ease; }
  .op-header_panelgrid { display: grid; grid-template-columns: minmax(13rem, 1fr) 2.4fr; gap: var(--_spacing---space--8); padding-top: var(--_spacing---space--7); padding-bottom: var(--_spacing---space--7); align-content: start; }
  .op-header_menucol { text-align: left; }
  .op-header_eyebrow { display: block; text-align: left; opacity: 0.55; margin-bottom: var(--_spacing---space--5); }
  .op-header_eyebrow--link:hover { opacity: 0.9; }
  .op-header_menulist { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0; }
  .op-header_menulink { font-family: var(--_typography---font--primary-family); font-size: 1.02rem; line-height: 1.15; color: currentColor; text-decoration: none; opacity: 0.7; transition: opacity 200ms; display: inline-block; border-bottom: 0.0625rem solid transparent; padding-block: 0.12rem; }
  .op-header_menulink:hover, .op-header_menulink.is-active { opacity: 1; border-bottom-color: currentColor; }
  .op-header_feature { position: relative; }
  .op-header_featuregroup { display: none; grid-template-columns: repeat(3, 1fr); gap: var(--_spacing---space--6); }
  .op-header_featuregroup.is-active { display: grid; }
  .op-header_pcard { text-decoration: none; color: currentColor; display: block; }
  .op-header_pmedia { display: block; aspect-ratio: var(--op-feat-ratio, 4 / 5); overflow: hidden; }
  .op-header_pimg { width: 100%; height: 100%; object-fit: cover; transition: transform 600ms ease; }
  .op-header_pcard:hover .op-header_pimg { transform: scale(1.04); }
  .op-header_pimg--ph { display: block; background-color: color-mix(in srgb, currentColor 12%, transparent); }
  .op-header_pname { display: block; margin-top: var(--_spacing---space--4); font-family: var(--_typography---font--primary-family); font-size: 0.95rem; }
  .op-header_empty { font-size: 0.85rem; opacity: 0.7; }

  /* Drawer móvil */
  .op-header_drawer { position: absolute; left: 0; right: 0; top: 100%; background-color: #ffffff; color: var(--swatch--brand-500, #5f604e); border-bottom: 0.0625rem solid var(--_theme---border); display: none; text-align: left; box-shadow: 0 1.5rem 2rem -1.5rem rgba(0,0,0,0.18); max-height: calc(100dvh - 3.5rem); overflow-y: auto; }
  .op-header_drawer.is-open { display: block; }
  .op-header_drawer .op-header_accsum, .op-header_drawer .op-header_accroot, .op-header_drawer .op-header_acclink { text-align: left; }
  .op-header_drawer .op-header_acclist { align-items: flex-start; }
  .op-header_drawer .op-header_acclink { display: block; width: 100%; }
  /* Header sólido (blanco) con el drawer móvil abierto */
  .op-header.is-drawer-open { background-color: #ffffff; color: var(--swatch--brand-500, #5f604e); border-bottom: 0.0625rem solid var(--_theme---border); }
  .op-header_drawerinner { padding-top: var(--_spacing---space--4); padding-bottom: var(--_spacing---space--5); display: flex; flex-direction: column; gap: 0; }
  .op-header_acc { border-bottom: 0.0625rem solid var(--_theme---border); }
  .op-header_acc:first-child { border-top: 0.0625rem solid var(--_theme---border); }
  .op-header_accsum { cursor: pointer; list-style: none; padding: var(--_spacing---space--4) 0; display: flex; align-items: center; justify-content: space-between; gap: var(--_spacing---space--4); }
  .op-header_accsum::-webkit-details-marker { display: none; }
  .op-header_chev { flex: none; opacity: 0.6; transition: transform 220ms ease; }
  .op-header_acc[open] > .op-header_accsum .op-header_chev { transform: rotate(180deg); }
  .op-header_chev--go { transform: none; }
  .op-header_acclist { list-style: none; margin: 0; padding: 0 0 var(--_spacing---space--4); display: flex; flex-direction: column; gap: var(--_spacing---space--3); }
  .op-header_acclink { font-family: var(--_typography---font--primary-family); text-transform: none; letter-spacing: 0; font-size: 1rem; opacity: 0.8; }
  .op-header_accroot { padding: var(--_spacing---space--4) 0; border-bottom: 0.0625rem solid var(--_theme---border); display: flex; align-items: center; justify-content: space-between; gap: var(--_spacing---space--4); }
  .op-header_drawerloc { padding-top: var(--_spacing---space--5); display: flex; flex-direction: column; gap: var(--_spacing---space--5); }
  .op-header_locrow { display: flex; flex-direction: column; gap: 0.45rem; }
  .op-header_locrow > span { font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.68rem; opacity: 0.6; }
  .op-loc--drawer { display: block; }
  .op-loc--drawer .op-loc_select { width: 100%; border: 0.0625rem solid var(--_theme---border); border-radius: 2rem; padding: 0.75rem 1.1rem; font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.78rem; color: currentColor; background-color: transparent; }

  @media (max-width: 990px) {
    .op-header_nav { display: none; }
    .op-header_panel { display: none; }
    .op-header_burger { display: inline-flex; }
    .op-header_actions .op-loc { display: none; }
  }
  .op-no-scroll { overflow: hidden; }
{% endstylesheet %}

{% schema %}
{
  "name": "Encabezado On Paper",
  "settings": [
    { "type": "header", "content": "Navegación" },
    { "type": "text", "id": "products_label", "label": "Etiqueta Products", "default": "Products" },
    { "type": "text", "id": "collections_label", "label": "Etiqueta Collections", "default": "Collections" },
    { "type": "text", "id": "others_label", "label": "Etiqueta Others", "default": "Others" },
    { "type": "url", "id": "others_link", "label": "Others — enlace" },
    { "type": "header", "content": "Panel Products" },
    { "type": "collection", "id": "products_collection", "label": "Colección que lista los productos (vacío = todos)" },
    { "type": "collection", "id": "bestsellers_collection", "label": "Best sellers (3 productos a la derecha)" },
    { "type": "text", "id": "products_eyebrow", "label": "Eyebrow", "default": "View all" },
    { "type": "url", "id": "products_eyebrow_link", "label": "Eyebrow — enlace" },
    { "type": "header", "content": "Panel Collections" },
    { "type": "text", "id": "collections_eyebrow", "label": "Eyebrow", "default": "View all" },
    { "type": "url", "id": "collections_eyebrow_link", "label": "Eyebrow — enlace" },
    { "type": "header", "content": "Panel (apariencia)" },
    { "type": "select", "id": "feature_ratio", "label": "Proporción de imagen de producto", "options": [
      { "value": "4 / 5", "label": "4:5 (retrato suave)" },
      { "value": "5 / 6", "label": "5:6" },
      { "value": "1 / 1", "label": "1:1" },
      { "value": "2 / 3", "label": "2:3 (alta)" },
      { "value": "3 / 2", "label": "3:2" }
    ], "default": "4 / 5" }
  ]
}
{% endschema %}
