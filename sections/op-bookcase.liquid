{% comment %} On Paper — Bookcase (Lumos). Tira full-bleed de imágenes con disco que sigue el cursor. Componente propio, reordenable. {% endcomment %}
<section class="op-bookcase u-section full-width" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px" {{ section.shopify_attributes }}>
  {%- assign strip_tag = 'div' -%}
  {%- if section.settings.strip_link != blank -%}{%- assign strip_tag = 'a' -%}{%- endif -%}
  <{{ strip_tag }} class="op-bookcase_strip" data-cursor-follow style="--op-bookcase-cols: {{ section.blocks.size | at_least: 1 }}; --op-bookcase-ratio: {{ section.settings.ratio }}" {% if section.settings.strip_link != blank %}href="{{ section.settings.strip_link }}" aria-label="{{ section.settings.strip_label }}"{% endif %}>
    {%- for block in section.blocks -%}
      <div class="op-bookcase_cell" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 900 | image_tag: alt: block.settings.image.alt, class: 'op-bookcase_img', widths: '300,500,700,900', sizes: '25vw', loading: 'lazy' }}
        {%- else -%}
          <div class="op-bookcase_img op-bookcase_img--ph"></div>
        {%- endif -%}
      </div>
    {%- endfor -%}
    {%- if section.settings.strip_label != blank -%}
      <span class="op-bookcase_disc" data-cursor-disc aria-hidden="true">{{ section.settings.strip_label }}</span>
    {%- endif -%}
  </{{ strip_tag }}>
</section>

{% stylesheet %}
  .op-bookcase_strip { position: relative; display: grid; grid-template-columns: repeat(var(--op-bookcase-cols, 4), 1fr); cursor: none; text-decoration: none; color: inherit; }
  .op-bookcase_cell { overflow: hidden; }
  .op-bookcase_img { width: 100%; height: 100%; aspect-ratio: var(--op-bookcase-ratio, 0.8); object-fit: cover; display: block; transition: transform 700ms ease; }
  .op-bookcase_img--ph { background-color: color-mix(in srgb, var(--_theme---text) 10%, transparent); }
  .op-bookcase_strip:hover .op-bookcase_img { transform: scale(1.03); }
  .op-bookcase_disc {
    position: absolute; top: 0; left: 0; /* posición vía transform (JS, lerp) */
    display: grid; place-items: center; text-align: center;
    width: 8.5rem; height: 8.5rem; border-radius: 50%;
    background-color: rgba(245,245,239,0.65); backdrop-filter: blur(6px);
    color: #5f604e; font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.74rem;
    pointer-events: none; z-index: 3;
    opacity: 0; transition: opacity 280ms ease; will-change: transform, opacity;
  }
  .op-bookcase_disc.is-active { opacity: 1; }
  @media (hover: none) { .op-bookcase_strip { cursor: pointer; } }
  @media (max-width: 600px) { .op-bookcase_strip { grid-template-columns: repeat(2, 1fr); } }
{% endstylesheet %}

{% schema %}
{
  "name": "On Paper Bookcase",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Espacio arriba", "min": 0, "max": 200, "step": 4, "default": 64, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Espacio abajo", "min": 0, "max": 200, "step": 4, "default": 64, "unit": "px" },
    { "type": "select", "id": "ratio", "label": "Proporción de cada imagen", "options": [
      { "value": "0.75", "label": "Horizontal (4:3)" },
      { "value": "0.8", "label": "Vertical suave (5:4)" },
      { "value": "1", "label": "Cuadrada" },
      { "value": "1.25", "label": "Vertical (4:5)" },
      { "value": "1.4", "label": "Retrato" }
    ], "default": "0.8" },
    { "type": "text", "id": "strip_label", "label": "Texto del disco (sigue el cursor)", "default": "Book case" },
    { "type": "url", "id": "strip_link", "label": "Link de la tira" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Imagen",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" }
      ]
    }
  ],
  "presets": [{
    "name": "On Paper Bookcase",
    "blocks": [
      { "type": "image" },
      { "type": "image" },
      { "type": "image" },
      { "type": "image" }
    ]
  }]
}
{% endschema %}
