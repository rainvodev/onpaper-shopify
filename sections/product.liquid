{% comment %} On Paper — Página de producto (Lumos). Galería + info + personalización por bloques (line-item
  properties, sin variantes) + relacionados. Calcado del XD; un template por producto define los bloques. {% endcomment %}
<section class="op-product u-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px" data-op-handle="{{ product.handle }}" data-op-money="{{ shop.money_format | strip_html | escape }}"{% if product.variants.size > 1 %} data-op-variant-mode="1"{% endif %} {{ section.shopify_attributes }}>
  <div class="op-product_contain u-container">
    {%- if section.settings.back_label != blank -%}
      <a class="op-product_back" href="{{ section.settings.back_link | default: routes.all_products_collection_url }}">{{ section.settings.back_label }}</a>
    {%- endif -%}

    <div class="op-product_layout">
      {%- comment -%} Galería {%- endcomment -%}
      <div class="op-product_media">
        {%- if product.featured_media -%}
          <div class="op-product_main" data-mask="up">
            {{ product.featured_media | image_url: width: 1400 | image_tag: alt: product.title, class: 'op-product_mainimg', id: 'opMainImg', widths: '500,800,1100,1400', sizes: '(min-width: 750px) 50vw, 100vw' }}
          </div>
          {%- if product.media.size > 1 -%}
            <div class="op-product_thumbs">
              {%- for media in product.media limit: 3 -%}
                {%- unless forloop.first -%}
                  <button type="button" class="op-product_thumb" data-op-thumb data-full="{{ media | image_url: width: 1400 }}" aria-label="Ver imagen {{ forloop.index }}">
                    {{ media | image_url: width: 480 | image_tag: alt: media.alt | default: product.title, class: 'op-product_thumbimg', widths: '240,480', loading: 'lazy' }}
                  </button>
                {%- endunless -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="op-product_main"><div class="op-product_mainimg op-product_mainimg--ph"></div></div>
          <div class="op-product_thumbs">
            <span class="op-product_thumb op-product_thumb--ph"></span>
            <span class="op-product_thumb op-product_thumb--ph"></span>
            <span class="op-product_thumb op-product_thumb--ph"></span>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Info {%- endcomment -%}
      <div class="op-product_info">
        {%- comment -%} Título + intro (heading block o fallback) {%- endcomment -%}
        {%- assign has_heading = false -%}
        {%- for block in section.blocks -%}{%- if block.type == 'heading' -%}{%- assign has_heading = true -%}{%- endif -%}{%- endfor -%}
        {%- if has_heading -%}
          {%- for block in section.blocks -%}{%- if block.type == 'heading' -%}
            <h1 class="op-product_title" data-reveal-load {{ block.shopify_attributes }}>{{ block.settings.title }}</h1>
            {%- if block.settings.intro != blank -%}<div class="op-product_intro rte" data-reveal-load style="--reveal-delay: 100ms">{{ block.settings.intro }}</div>{%- endif -%}
          {%- endif -%}{%- endfor -%}
        {%- else -%}
          <h1 class="op-product_title" data-reveal-load>{{ product.title }}</h1>
          {%- if product.description != blank -%}<div class="op-product_intro rte" data-reveal-load style="--reveal-delay: 100ms">{{ product.description }}</div>{%- endif -%}
        {%- endif -%}

        <div class="op-product_price" data-op-price data-reveal-load style="--reveal-delay: 180ms">
          {%- if product.compare_at_price > product.price -%}
            <span class="op-product_price-now" data-op-price-amount>{{ product.price | money }}</span>
            <s class="op-product_price-was">{{ product.compare_at_price | money }}</s>
          {%- else -%}<span data-op-price-amount>{{ product.price | money }}</span>{%- endif -%}
        </div>

        {%- comment -%} Acordeones DETAILS / SHIPPING {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            <details class="op-product_acc" {{ block.shopify_attributes }}>
              <summary class="op-product_acc-sum">{{ block.settings.heading }}</summary>
              <div class="op-product_acc-body rte">{{ block.settings.content }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}

        {%- form 'product', product, id: 'opProductForm', class: 'op-product_form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- if product.variants.size > 1 -%}
            <script type="application/json" data-op-variants>{{ product.variants | json }}</script>
            <script type="application/json" data-op-options>{{ product.options | json }}</script>
          {%- endif -%}

          {%- if section.settings.personalize_heading != blank -%}
            <h2 class="op-product_personalize" data-reveal>{{ section.settings.personalize_heading }}</h2>
          {%- endif -%}

          {%- for block in section.blocks -%}
            {%- assign label = block.settings.label -%}
            {%- case block.type -%}

              {%- when 'pills' -%}
                {%- assign opts = block.settings.options | split: ',' -%}
                {%- capture body -%}
                  <div class="op-product_pills" data-op-picker data-prop="{{ label | escape }}">
                    <input type="hidden" name="properties[{{ label }}]" value="{{ block.settings.default | default: opts.first | strip }}">
                    {%- for o in opts -%}
                      {%- assign ov = o | strip -%}
                      <button type="button" class="op-product_pill{% if ov == block.settings.default %} is-active{% endif %}" data-val="{{ ov | escape }}">{{ ov }}</button>
                    {%- endfor -%}
                  </div>
                {%- endcapture -%}
                {% render 'op-field-group', block: block, label: label, body: body %}

              {%- when 'swatch' -%}
                {%- capture body -%}{% render 'op-swatches', palette: block.settings.palette, property: label, default: block.settings.default %}{%- endcapture -%}
                {% render 'op-field-group', block: block, label: label, body: body, hint: block.settings.default %}

              {%- when 'size' -%}
                {%- capture body -%}{% render 'op-sizes', set: block.settings.set, property: label, default: block.settings.default %}{%- endcapture -%}
                {% render 'op-field-group', block: block, label: label, body: body, hint: block.settings.note %}

              {%- when 'dropdown' -%}
                {%- assign opts = block.settings.options | split: ',' -%}
                <label class="op-product_field" {{ block.shopify_attributes }}>
                  <span class="op-product_field-label">{{ label }}</span>
                  <select class="op-product_select" name="properties[{{ label }}]">
                    {%- for o in opts -%}<option value="{{ o | strip | escape }}">{{ o | strip }}</option>{%- endfor -%}
                  </select>
                </label>

              {%- when 'radio' -%}
                {%- assign opts = block.settings.options | split: ',' -%}
                <div class="op-product_field" {{ block.shopify_attributes }}>
                  <span class="op-product_field-label">{{ label }}</span>
                  <div class="op-product_radios" data-op-picker data-prop="{{ label | escape }}">
                    <input type="hidden" name="properties[{{ label }}]" value="{{ block.settings.default | default: opts.first | strip }}">
                    {%- for o in opts -%}
                      {%- assign ov = o | strip -%}
                      <button type="button" class="op-product_radio{% if ov == block.settings.default %} is-active{% endif %}" data-val="{{ ov | escape }}"><span class="op-product_radio-dot"></span>{{ ov }}</button>
                    {%- endfor -%}
                  </div>
                  {%- if block.settings.note != blank -%}<p class="op-product_note">{{ block.settings.note }}</p>{%- endif -%}
                </div>

              {%- when 'text' -%}
                <label class="op-product_field" {{ block.shopify_attributes }}>
                  <span class="op-product_field-label">{{ label }}</span>
                  <input type="text" name="properties[{{ label }}]" placeholder="{{ block.settings.placeholder }}" {% if block.settings.required %}required{% endif %}>
                </label>

              {%- when 'textarea' -%}
                <label class="op-product_field" {{ block.shopify_attributes }}>
                  <span class="op-product_field-label">{{ label }}</span>
                  <textarea name="properties[{{ label }}]" rows="3" placeholder="{{ block.settings.placeholder }}"></textarea>
                </label>

              {%- when 'url' -%}
                <label class="op-product_field" {{ block.shopify_attributes }}>
                  <span class="op-product_field-label">{{ label }}</span>
                  <input type="url" name="properties[{{ label }}]" placeholder="{{ block.settings.placeholder | default: 'Ingresa el URL' }}">
                </label>
                {%- if block.settings.note != blank -%}<p class="op-product_note">{{ block.settings.note }}</p>{%- endif -%}

              {%- when 'stepper' -%}
                <div class="op-product_field" {{ block.shopify_attributes }}>
                  <span class="op-product_field-label">{{ label }}</span>
                  <div class="op-product_stepper" data-op-stepper>
                    <button type="button" data-step="-1" aria-label="Restar">&#8211;</button>
                    <input type="number" name="properties[{{ label }}]" value="{{ block.settings.default | default: block.settings.min }}" min="{{ block.settings.min }}" inputmode="numeric">
                    <button type="button" data-step="1" aria-label="Sumar">+</button>
                  </div>
                  {%- if block.settings.note != blank -%}<p class="op-product_note">{{ block.settings.note }}</p>{%- endif -%}
                </div>

              {%- when 'gift_type' -%}
                <div class="op-product_field" {{ block.shopify_attributes }}>
                  <span class="op-product_field-label">{{ label }}</span>
                  <div class="op-product_pills op-product_gift" data-op-picker data-prop="{{ label | escape }}" data-op-gift>
                    <input type="hidden" name="properties[{{ label }}]" value="{{ block.settings.option_a }}">
                    <button type="button" class="op-product_pill is-active" data-val="{{ block.settings.option_a | escape }}" data-gift="a">{{ block.settings.option_a }}</button>
                    <button type="button" class="op-product_pill" data-val="{{ block.settings.option_b | escape }}" data-gift="b">{{ block.settings.option_b }}</button>
                  </div>
                  {%- assign gopts = block.settings.products | split: ',' -%}
                  <div class="op-product_gift-pane" data-gift-pane="a">
                    <select class="op-product_select" name="properties[Producto]">
                      <option value="">{{ block.settings.products_placeholder | default: 'Selecciona el producto…' }}</option>
                      {%- for o in gopts -%}<option value="{{ o | strip | escape }}">{{ o | strip }}</option>{%- endfor -%}
                    </select>
                  </div>
                  <div class="op-product_gift-pane" data-gift-pane="b" hidden>
                    <input type="text" name="properties[Crédito / Saldo]" placeholder="{{ block.settings.amount_placeholder | default: 'Agrega el monto…' }}">
                  </div>
                </div>

              {%- when 'note' -%}
                <p class="op-product_note" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>

            {%- endcase -%}
          {%- endfor -%}

          {%- comment -%} Cantidad (line qty) {%- endcomment -%}
          {%- if section.settings.show_qty -%}
          <div class="op-product_field op-product_qty">
            <span class="op-product_field-label">{{ section.settings.qty_label | default: 'Cantidad' }}</span>
            {%- if section.settings.qty_style == 'stepper' -%}
              <div class="op-product_stepper" data-op-stepper>
                <button type="button" data-step="-1" aria-label="Restar">&#8211;</button>
                <input type="number" name="quantity" value="{{ section.settings.qty_min | default: 1 }}" min="{{ section.settings.qty_min | default: 1 }}" inputmode="numeric">
                <button type="button" data-step="1" aria-label="Sumar">+</button>
              </div>
            {%- else -%}
              <select class="op-product_select" name="quantity">
                {%- for i in (1..10) -%}<option value="{{ i }}">{{ i }}</option>{%- endfor -%}
              </select>
            {%- endif -%}
            {%- if section.settings.qty_note != blank -%}<p class="op-product_note">{{ section.settings.qty_note }}</p>{%- endif -%}
          </div>
          {%- endif -%}

          <button type="submit" name="add" class="op-product_add">{{ section.settings.add_label | default: 'Agregar al carrito' }}</button>
          {%- if section.settings.show_buy_now -%}{{ form | payment_button }}{%- endif -%}
        {%- endform -%}
      </div>
    </div>

    {%- comment -%} Relacionados {%- endcomment -%}
    {%- if section.settings.show_related -%}
      {%- assign related = product.collections.first.products -%}
      {%- if related == blank or related.size < 2 -%}{%- assign related = collections.all.products -%}{%- endif -%}
      {%- if related and related.size > 1 -%}
        <div class="op-product_related" data-reveal>
          <h2 class="op-product_related-h">{{ section.settings.related_heading | default: 'You may also like…' }}</h2>
          <div class="op-product_related-grid">
            {%- assign shown = 0 -%}
            {%- for p in related -%}
              {%- if p.id != product.id and shown < 3 -%}
                {%- assign shown = shown | plus: 1 -%}
                {% render 'op-product-card-mini', product: p %}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- comment -%} Barra flotante: aparece al perder de vista el precio {%- endcomment -%}
  <div class="op-product_sticky" data-op-sticky aria-hidden="true">
    <div class="op-product_sticky-in">
      <div class="op-product_sticky-info">
        <span class="op-product_sticky-title">{{ product.title }}</span>
        <span class="op-product_sticky-price" data-op-price-amount>{{ product.price | money }}</span>
      </div>
      <button type="submit" name="add" form="opProductForm" class="op-product_sticky-add">{{ section.settings.add_label | default: 'Agregar al carrito' }}</button>
    </div>
  </div>
</section>

{% stylesheet %}
  .op-product_back { display: inline-block; width: fit-content; justify-self: start; font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.72rem; color: currentColor; text-decoration: none; border: 0.0625rem solid var(--_theme---border); border-radius: 2rem; padding: 0.55rem 1.3rem; margin-bottom: var(--_spacing---space--7); }
  .op-product_layout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--_spacing---space--8); align-items: start; }
  .op-product_media { position: sticky; top: 2rem; align-self: start; }
  .op-product_main { overflow: hidden; }
  .op-product_mainimg { width: 100%; height: auto; display: block; aspect-ratio: 4 / 5; object-fit: cover; }
  .op-product_mainimg--ph { background-color: color-mix(in srgb, var(--_theme---text) 10%, transparent); }
  .op-product_thumbs { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--_spacing---space--4); margin-top: var(--_spacing---space--4); }
  .op-product_thumb { padding: 0; border: 0; background: none; cursor: pointer; overflow: hidden; aspect-ratio: 1 / 1; }
  .op-product_thumb--ph { background-color: color-mix(in srgb, var(--_theme---text) 8%, transparent); cursor: default; }
  .op-product_thumbimg { width: 100%; height: 100%; object-fit: cover; display: block; }

  .op-product_title { font-family: var(--_typography---font--primary-family); font-size: clamp(1.7rem, 1.1rem + 2vw, 2.4rem); line-height: 1.12; }
  .op-product_title em { font-style: italic; }
  .op-product_intro { margin-top: var(--_spacing---space--4); max-width: 52ch; opacity: 0.85; font-size: 0.95rem; }
  .op-product_intro p { margin: 0 0 0.6em; }
  .op-product_price { font-size: 1.3rem; margin-top: var(--_spacing---space--5); }
  .op-product_price-was { opacity: 0.5; margin-left: 0.5rem; }

  .op-product_acc { border-top: 0.0625rem solid var(--_theme---border); }
  .op-product_acc:first-of-type { margin-top: var(--_spacing---space--6); }
  .op-product_acc-sum { cursor: pointer; padding: var(--_spacing---space--4) 0; font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.76rem; list-style: none; display: flex; align-items: center; gap: 0.6rem; }
  .op-product_acc-sum::-webkit-details-marker { display: none; }
  .op-product_acc-sum::before { content: "\2193"; font-size: 0.8rem; opacity: 0.7; }
  .op-product_acc[open] .op-product_acc-sum::before { content: "\2191"; }
  .op-product_acc-body { padding-bottom: var(--_spacing---space--5); font-size: 0.9rem; opacity: 0.85; }
  .op-product_acc-body p { margin: 0 0 0.7em; }
  .op-product_acc-body p:first-child { font-style: italic; }

  .op-product_personalize { font-family: var(--_typography---font--primary-family); font-size: 1.4rem; margin-top: var(--_spacing---space--7); margin-bottom: var(--_spacing---space--5); font-weight: 400; }

  /* Grupo colapsable (Material/Tamaño/Color/Hotstamping) */
  .op-product_grp { border: 0; }
  .op-product_grp-sum { cursor: pointer; list-style: none; display: flex; align-items: baseline; gap: 0.5rem; padding: var(--_spacing---space--4) 0 var(--_spacing---space--3); font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.74rem; }
  .op-product_grp-sum::-webkit-details-marker { display: none; }
  .op-product_grp-sum::before { content: "\2193"; opacity: 0.7; }
  .op-product_grp[open] .op-product_grp-sum::before { content: "\2191"; }
  .op-product_grp-hint { text-transform: none; letter-spacing: 0; font-style: italic; opacity: 0.55; font-size: 0.92em; }
  .op-product_grp-body { padding-bottom: var(--_spacing---space--5); }

  /* Pills */
  .op-product_pills { display: flex; flex-wrap: wrap; gap: var(--_spacing---space--3); }
  .op-product_pill { font-family: var(--font-label); font-size: 0.8rem; color: currentColor; background: transparent; border: 0.0625rem solid var(--_theme---border); border-radius: 2rem; padding: 0.6rem 1.3rem; cursor: pointer; transition: background-color 200ms, color 200ms; }
  .op-product_pill.is-active { background-color: var(--swatch--brand-300, #b0b094); border-color: transparent; color: #fff; }

  /* Swatches */
  .op-product_swatches { display: flex; flex-wrap: wrap; gap: var(--_spacing---space--4); }
  .op-product_swatch { width: 2.6rem; height: 2.6rem; border-radius: 50%; padding: 0; border: 0.0625rem solid color-mix(in srgb, var(--_theme---text) 20%, transparent); background-size: cover; background-position: center; cursor: pointer; position: relative; }
  .op-product_swatch.is-active { outline: 0.125rem solid var(--_theme---text); outline-offset: 0.15rem; }

  /* Sizes */
  .op-product_sizes { display: flex; flex-wrap: wrap; align-items: flex-end; gap: var(--_spacing---space--5); }
  .op-product_size { background: none; border: 0; padding: 0; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: currentColor; }
  .op-product_size-box { width: var(--w); height: var(--h); background-color: color-mix(in srgb, var(--_theme---text) 8%, transparent); border: 0.0625rem solid transparent; }
  .op-product_size.is-active .op-product_size-box { background-color: var(--swatch--brand-300, #b0b094); }
  .op-product_size-label { font-size: 0.78rem; opacity: 0.75; }
  .op-product_size.is-active .op-product_size-label { opacity: 1; }

  /* Campos */
  .op-product_field { display: flex; flex-direction: column; gap: 0.5rem; margin-top: var(--_spacing---space--5); }
  .op-product_field-label { font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.74rem; opacity: 0.85; }
  .op-product_select, .op-product_field input[type="text"], .op-product_field input[type="url"], .op-product_field input[type="number"], .op-product_field textarea, .op-product_gift-pane select, .op-product_gift-pane input { font-family: inherit; font-size: 0.95rem; color: var(--_theme---text); background-color: transparent; border: 0.0625rem solid var(--_theme---border); border-radius: 2rem; padding: 0.85rem 1.2rem; width: 100%; }
  .op-product_field textarea { border-radius: 1rem; resize: vertical; }
  .op-product_note { font-size: 0.8rem; font-style: italic; opacity: 0.6; margin-top: var(--_spacing---space--3); }

  /* Radios */
  .op-product_radios { display: flex; gap: var(--_spacing---space--6); }
  .op-product_radio { display: inline-flex; align-items: center; gap: 0.5rem; background: none; border: 0; cursor: pointer; color: currentColor; font-size: 0.95rem; padding: 0; }
  .op-product_radio-dot { width: 1.1rem; height: 1.1rem; border-radius: 50%; border: 0.0625rem solid var(--_theme---text); display: inline-block; position: relative; }
  .op-product_radio.is-active .op-product_radio-dot::after { content: ""; position: absolute; inset: 0.22rem; border-radius: 50%; background-color: var(--swatch--brand-300, #b0b094); }

  /* Stepper */
  .op-product_stepper { display: inline-flex; align-items: center; border: 0.0625rem solid var(--_theme---border); border-radius: 2rem; width: fit-content; }
  .op-product_stepper button { background: none; border: 0; cursor: pointer; font-size: 1rem; padding: 0.7rem 1.1rem; color: currentColor; }
  .op-product_stepper input { border: 0; width: 3.5rem; text-align: center; background: transparent; color: var(--_theme---text); -moz-appearance: textfield; }
  .op-product_stepper input::-webkit-outer-spin-button, .op-product_stepper input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .op-product_gift-pane { margin-top: var(--_spacing---space--3); }
  .op-product_qty .op-product_select { width: 8rem; }

  .op-product_add { width: 100%; margin-top: var(--_spacing---space--6); font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.8rem; color: var(--_theme---text); background-color: transparent; border: 0.0625rem solid var(--_theme---text); border-radius: 2rem; padding: 1rem 2rem; cursor: pointer; transition: background-color 250ms, color 250ms; }
  .op-product_add:hover { background-color: var(--_theme---text); color: var(--_theme---background); }
  .op-product_form .shopify-payment-button { margin-top: var(--_spacing---space--3); }
  .op-product_form .shopify-payment-button__button--unbranded { background-color: var(--swatch--brand-300, #b0b094); border-radius: 2rem; padding: 1rem 2rem; font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.8rem; }

  .op-product_related { margin-top: var(--_spacing---space--8); padding-top: var(--_spacing---space--7); border-top: 0.0625rem solid var(--_theme---border); }
  .op-product_related-h { font-family: var(--_typography---font--primary-family); font-style: italic; font-size: clamp(1.4rem, 1rem + 1.5vw, 2rem); margin-bottom: var(--_spacing---space--6); font-weight: 400; }
  .op-product_related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--_spacing---space--6); }

  @media (max-width: 900px) {
    .op-product_layout { grid-template-columns: 1fr; gap: var(--_spacing---space--6); }
    .op-product_media { position: static; }
    .op-product_related-grid { grid-template-columns: 1fr; }
  }

  /* Barra flotante de precio */
  .op-product_sticky { position: fixed; left: 0; right: 0; bottom: 0; z-index: 90; background: var(--_theme---background); border-top: 0.0625rem solid var(--_theme---border); transform: translateY(100%); transition: transform 300ms ease; box-shadow: 0 -0.5rem 1.5rem -0.8rem rgba(0,0,0,0.2); }
  .op-product_sticky.is-visible { transform: translateY(0); }
  .op-product_sticky-in { display: flex; align-items: center; justify-content: space-between; gap: var(--_spacing---space--5); padding: 0.7rem var(--_spacing---space--5); max-width: 68rem; margin: 0 auto; }
  .op-product_sticky-info { display: flex; flex-direction: column; line-height: 1.2; }
  .op-product_sticky-title { font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.66rem; opacity: 0.7; }
  .op-product_sticky-price { font-size: 1.15rem; }
  .op-product_sticky-add { font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.76rem; color: var(--_theme---background); background: var(--_theme---text); border: 0; border-radius: 2rem; padding: 0.85rem 1.6rem; cursor: pointer; white-space: nowrap; }
  @media (prefers-reduced-motion: reduce) { .op-product_sticky { transition: none; } }
  @media (max-width: 430px) {
    .op-product_sticky-title { display: none; }
    .op-product_sticky-in { padding: 0.6rem var(--_spacing---space--4); }
    .op-product_sticky-add { flex: 1; text-align: center; }
  }
{% endstylesheet %}

