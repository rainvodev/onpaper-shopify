{% comment %} On Paper — Crear cuenta. {% endcomment %}
{% render 'op-account-styles' %}
<section class="u-section"><div class="u-container"><div class="op-acct">
  <h1 class="op-acct_title">Crear cuenta</h1>
  {% form 'create_customer', class: 'op-acct_form' %}
    {% if form.errors %}<div class="op-acct_errors">{{ form.errors | default_errors }}</div>{% endif %}
    <label class="op-acct_field"><span>Nombre</span><input type="text" name="customer[first_name]" autocomplete="given-name"></label>
    <label class="op-acct_field"><span>Apellido</span><input type="text" name="customer[last_name]" autocomplete="family-name"></label>
    <label class="op-acct_field"><span>{{ 'customers.login.email' | t }}</span><input type="email" name="customer[email]" autocomplete="email" required></label>
    <label class="op-acct_field"><span>{{ 'customers.login.password' | t }}</span><input type="password" name="customer[password]" autocomplete="new-password" required></label>
    <button type="submit" class="op-acct_submit">Crear cuenta</button>
  {% endform %}
  <div class="op-acct_links"><a class="op-acct_link" href="{{ routes.account_login_url }}">¿Ya tienes cuenta? Inicia sesión</a></div>
</div></div></section>
{% schema %}{ "name": "Registro", "settings": [] }{% endschema %}
