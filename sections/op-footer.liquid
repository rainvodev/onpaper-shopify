        {{ section.settings.logo | image_url: width: 600 | image_tag: alt: shop.name, class: 'op-footer_logo', widths: '240,400,600' }}
      {%- else -%}
        <svg class="op-footer_mark" viewBox="0 0 88 112" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="On Paper">
          <mask id="op-footer-mark-mask" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="88" height="112">
