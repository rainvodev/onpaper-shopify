{% comment %} On Paper — Footer (Lumos). Wordmark circular + Whatsapp/contacto/redes. Layout aireado del XD. {% endcomment %}
<footer class="op-footer full-width u-theme-dark" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; min-height: {{ section.settings.min_height }}px" {{ section.shopify_attributes }}>
  {%- if section.settings.bg_image != blank -%}
    {{ section.settings.bg_image | image_url: width: 2400 | image_tag: alt: '', class: 'op-footer_bg', widths: '800,1200,1800,2400', sizes: '100vw', loading: 'lazy' }}
    <div class="op-footer_veil"></div>
  {%- endif -%}
  <div class="op-footer_contain u-container">
    <div class="op-footer_brand" data-reveal="fade">
