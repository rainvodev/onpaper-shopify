{% comment %} On Paper — Collection banner (Lumos). Imagen full-bleed + texto a la izquierda dentro del container + botón. {% endcomment %}
<section class="op-cbanner u-section full-width u-theme-dark" style="--op-cbanner-hw: {{ section.settings.heading_width }}ch; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px" {{ section.shopify_attributes }}>
  {%- if section.settings.image != blank -%}
    {%- assign banner_alt = section.settings.heading | strip_html -%}
    {{ section.settings.image | image_url: width: 3000 | image_tag: alt: banner_alt, class: 'op-cbanner_img', widths: '800,1200,1800,2400,3000', sizes: '100vw', loading: 'lazy' }}
  {%- endif -%}
  {%- if section.settings.overlay > 0 -%}
    <div class="op-cbanner_overlay" style="opacity: {{ section.settings.overlay | divided_by: 100.0 }}"></div>
  {%- endif -%}
  <div class="op-cbanner_contain u-container">
    <div class="op-cbanner_content">
      {%- if section.settings.heading != blank -%}
        <div class="op-cbanner_heading" role="heading" aria-level="2" data-reveal style="--reveal-delay: 0ms">{{ section.settings.heading }}</div>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a class="op-cbanner_cta" href="{{ section.settings.cta_link | default: '#' }}" data-reveal style="--reveal-delay: 150ms">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* u-section centra vertical; u-container alinea con el resto del sitio. Texto a la izquierda. */
  .op-cbanner { position: relative; overflow: hidden; isolation: isolate; }
  .op-cbanner_img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; }
  .op-cbanner_overlay { position: absolute; inset: 0; background-color: #000; z-index: -1; }
  .op-cbanner_content { width: 100%; text-align: left; }
  .op-cbanner_heading { max-width: var(--op-cbanner-hw, 30ch); font-family: var(--_typography---font--primary-family); font-size: clamp(1.75rem, 1.2rem + 2.4vw, 2.6rem); line-height: 1.15; color: var(--_theme---text); }
  .op-cbanner_heading p { margin: 0; }
  .op-cbanner_heading em { font-style: italic; }
  .op-cbanner_cta {
    display: inline-block; margin-top: var(--_spacing---space--6);
    font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.78rem;
    color: var(--_theme---text); text-decoration: none;
    background-color: rgba(255,255,255,0.14); backdrop-filter: blur(8px);
    border: 0.0625rem solid rgba(255,255,255,0.35); border-radius: 2rem;
    padding: 0.85rem 2rem; transition: background-color 300ms;
  }
  .op-cbanner_cta:hover { background-color: rgba(255,255,255,0.24); }
{% endstylesheet %}

{% schema %}
{
  "name": "On Paper Banner colección",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Espacio arriba", "min": 0, "max": 320, "step": 4, "default": 200, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Espacio abajo", "min": 0, "max": 320, "step": 4, "default": 200, "unit": "px" },
    { "type": "image_picker", "id": "image", "label": "Imagen de fondo" },
    { "type": "range", "id": "overlay", "label": "Oscurecer imagen", "min": 0, "max": 80, "step": 5, "default": 25, "unit": "%" },
    { "type": "range", "id": "heading_width", "label": "Ancho del título (caracteres)", "min": 14, "max": 50, "step": 1, "default": 30, "unit": "ch" },
    { "type": "richtext", "id": "heading", "label": "Título", "default": "<p>Get to know our <em>Photobook Collections.</em></p>" },
    { "type": "text", "id": "cta_label", "label": "Texto del botón", "default": "Shop now" },
    { "type": "url", "id": "cta_link", "label": "Link del botón" }
  ],
  "presets": [{ "name": "On Paper Banner colección" }]
}
{% endschema %}
