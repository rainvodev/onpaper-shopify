{% comment %} On Paper — Restablecer contraseña. {% endcomment %}
{% render 'op-account-styles' %}
<section class="u-section"><div class="u-container"><div class="op-acct">
  <h1 class="op-acct_title">Nueva contraseña</h1>
  {% form 'reset_customer_password', class: 'op-acct_form' %}
    {% if form.errors %}<div class="op-acct_errors">{{ form.errors | default_errors }}</div>{% endif %}
    <label class="op-acct_field"><span>Contraseña</span><input type="password" name="customer[password]" autocomplete="new-password" required></label>
    <label class="op-acct_field"><span>Confirmar contraseña</span><input type="password" name="customer[password_confirmation]" autocomplete="new-password" required></label>
    <button type="submit" class="op-acct_submit">Guardar</button>
  {% endform %}
</div></div></section>
{% schema %}{ "name": "Restablecer contraseña", "settings": [] }{% endschema %}
