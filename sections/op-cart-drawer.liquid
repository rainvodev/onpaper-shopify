{% comment %} On Paper — Cart drawer (Lumos). Carrito deslizable AJAX. Re-render vía Section Rendering API
  (?sections=op-cart-drawer). La lógica vive en assets/op-cart.js. {% endcomment %}
<div class="op-cart" data-op-cart data-op-cart-count-value="{{ cart.item_count }}" aria-hidden="true"
  data-op-money="{{ shop.money_format | strip_html | escape }}"
  data-op-url-cart="{{ routes.cart_url }}"
  data-op-url-cart-js="{{ routes.cart_url }}.js"
  data-op-url-change="{{ routes.cart_change_url }}.js"
  data-op-url-add="{{ routes.cart_add_url }}.js"
  data-l-error="{{ section.settings.error_text | default: 'No se pudo actualizar el carrito. Inténtalo de nuevo.' | escape }}"
  data-l-title="{{ section.settings.title | default: 'Carrito' | escape }}"
  data-l-subtotal="{{ section.settings.subtotal_label | default: 'Subtotal' | escape }}"
  data-l-checkout="{{ section.settings.checkout_label | default: 'Finalizar compra' | escape }}"
  data-l-view="{{ section.settings.view_label | default: 'Ver carrito' | escape }}"
  data-l-remove="{{ section.settings.remove_label | default: 'Quitar' | escape }}"
  data-l-empty="{{ section.settings.empty_text | default: 'Tu carrito está vacío.' | escape }}"
  data-l-continue="{{ section.settings.continue_label | default: 'Seguir comprando' | escape }}">
  <div class="op-cart_overlay" data-op-cart-close></div>
  <aside class="op-cart_panel" role="dialog" aria-modal="true" aria-label="{{ section.settings.title | default: 'Carrito' }}">
    <header class="op-cart_head">
      <span class="op-cart_title">{{ section.settings.title | default: 'Carrito' }} ({{ cart.item_count }})</span>
      <button type="button" class="op-cart_close" data-op-cart-close aria-label="Cerrar">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 5l14 14M19 5L5 19"/></svg>
      </button>
    </header>

    {%- if cart.item_count == 0 -%}
      <div class="op-cart_empty">
        <p>{{ section.settings.empty_text | default: 'Tu carrito está vacío.' }}</p>
        <button type="button" class="op-cart_continue" data-op-cart-close>{{ section.settings.continue_label | default: 'Seguir comprando' }}</button>
      </div>
    {%- else -%}
      <div class="op-cart_items" data-lenis-prevent>
        {%- for item in cart.items -%}
          <div class="op-cart_item" data-line="{{ forloop.index }}">
            <a href="{{ item.url }}" class="op-cart_item-media">
              {%- if item.image -%}
                {{ item.image | image_url: width: 240 | image_tag: alt: item.product.title, widths: '120,240', loading: 'lazy', class: 'op-cart_item-img' }}
              {%- else -%}<span class="op-cart_item-img op-cart_item-img--ph"></span>{%- endif -%}
            </a>
            <div class="op-cart_item-info">
              <a href="{{ item.url }}" class="op-cart_item-title">{{ item.product.title }}</a>
              {%- unless item.product.has_only_default_variant -%}
                {%- if item.variant.title != blank -%}<div class="op-cart_item-variant">{{ item.variant.title }}</div>{%- endif -%}
              {%- endunless -%}
              {%- assign has_props = false -%}
              {%- for p in item.properties -%}{%- if p.last != blank -%}{%- assign first_char = p.first | slice: 0 -%}{%- unless first_char == '_' or item.product.options contains p.first -%}{%- assign has_props = true -%}{%- endunless -%}{%- endif -%}{%- endfor -%}
              {%- if has_props -%}
                <ul class="op-cart_item-props">
                  {%- for p in item.properties -%}
                    {%- if p.last != blank -%}
                      {%- assign first_char = p.first | slice: 0 -%}
                      {%- unless first_char == '_' or item.product.options contains p.first -%}<li><span>{{ p.first }}:</span> {{ p.last }}</li>{%- endunless -%}
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}
              <div class="op-cart_item-bottom">
                <div class="op-cart_qty">
                  <button type="button" data-op-cart-minus aria-label="Restar">&#8211;</button>
                  <span class="op-cart_qty-val" data-op-cart-qtyval>{{ item.quantity }}</span>
                  <button type="button" data-op-cart-plus aria-label="Sumar">+</button>
                </div>
                <span class="op-cart_item-price">{{ item.final_line_price | money }}</span>
              </div>
              <button type="button" class="op-cart_remove" data-op-cart-remove>{{ section.settings.remove_label | default: 'Quitar' }}</button>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <footer class="op-cart_foot">
        <div class="op-cart_subtotal">
          <span>{{ section.settings.subtotal_label | default: 'Subtotal' }}</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <form action="{{ routes.cart_url }}" method="post">
          <button type="submit" name="checkout" class="op-cart_checkout">{{ section.settings.checkout_label | default: 'Finalizar compra' }}</button>
        </form>
        <a href="{{ routes.cart_url }}" class="op-cart_view">{{ section.settings.view_label | default: 'Ver carrito' }}</a>
      </footer>
    {%- endif -%}
  </aside>
</div>

{% stylesheet %}
  /* visibility se retrasa al cerrar (0s tras 480ms) para que el panel alcance a animar su salida
     — sin esto, el contenedor se ocultaría al instante y el cierre no reproduciría la apertura en reversa. */
  .op-cart { position: fixed; inset: 0; z-index: 100; visibility: hidden; pointer-events: none; transition: visibility 0s linear 480ms; }
  .op-cart.is-open { visibility: visible; pointer-events: auto; transition: visibility 0s; }
  .op-cart_overlay { position: absolute; inset: 0; background-color: rgba(30,30,26,0.35); opacity: 0; transition: opacity 320ms ease; }
  .op-cart.is-open .op-cart_overlay { opacity: 1; }
  .op-cart_panel { position: absolute; top: 0; right: 0; height: 100%; width: clamp(20rem, 90vw, 27rem); background-color: var(--swatch--light-200, #f5f5ef); color: var(--_theme---text); display: flex; flex-direction: column; clip-path: inset(0 0 0 100%); transition: clip-path 480ms cubic-bezier(0.16, 1, 0.3, 1); box-shadow: -1rem 0 2.5rem -1rem rgba(0,0,0,0.25); }
  .op-cart.is-open .op-cart_panel { clip-path: inset(0 0 0 0%); }
  @media (prefers-reduced-motion: reduce) { .op-cart, .op-cart_panel, .op-cart_overlay { transition: none; } }

  .op-cart_head { display: flex; align-items: center; justify-content: space-between; padding: var(--_spacing---space--5) var(--_spacing---space--6); border-bottom: 0.0625rem solid var(--_theme---border); }
  .op-cart_title { font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.82rem; }
  .op-cart_close { background: none; border: 0; cursor: pointer; color: currentColor; padding: 0; display: inline-flex; }

  .op-cart_empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--_spacing---space--5); text-align: center; padding: var(--_spacing---space--6); }
  .op-cart_empty p { opacity: 0.7; }

  .op-cart_items { flex: 1; overflow-y: auto; padding: var(--_spacing---space--5) var(--_spacing---space--6); display: flex; flex-direction: column; gap: var(--_spacing---space--5); }
  .op-cart_item { display: grid; grid-template-columns: 4.5rem 1fr; gap: var(--_spacing---space--4); }
  .op-cart_item-media { display: block; aspect-ratio: 4 / 5; overflow: hidden; }
  .op-cart_item-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .op-cart_item-img--ph { display: block; background-color: color-mix(in srgb, var(--_theme---text) 10%, transparent); }
  .op-cart_item-title { font-family: var(--_typography---font--primary-family); font-size: 1rem; color: currentColor; text-decoration: none; }
  .op-cart_item-variant { font-size: 0.78rem; opacity: 0.72; margin-top: 0.15rem; }
  .op-cart_item-props { list-style: none; margin: 0.35rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 0.1rem; }
  .op-cart_item-props li { font-size: 0.74rem; opacity: 0.65; }
  .op-cart_item-props span { opacity: 0.8; }
  .op-cart_item-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: var(--_spacing---space--4); }
  .op-cart_qty { display: inline-flex; align-items: center; border: 0.0625rem solid var(--_theme---border); border-radius: 2rem; transition: opacity 200ms; }
  .op-cart_qty.is-busy { opacity: 0.45; pointer-events: none; }
  .op-cart_error { font-size: 0.8rem; color: #a4472f; margin: 0; }
  .op-cart_qty button { background: none; border: 0; cursor: pointer; color: currentColor; padding: 0.35rem 0.7rem; font-size: 0.95rem; }
  .op-cart_qty-val { min-width: 1.5rem; text-align: center; font-size: 0.9rem; }
  .op-cart_item-price { font-size: 0.9rem; }
  .op-cart_remove { background: none; border: 0; cursor: pointer; color: currentColor; padding: 0; margin-top: var(--_spacing---space--3); font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.68rem; opacity: 0.6; transition: opacity 200ms; }
  .op-cart_remove:hover { opacity: 1; }

  .op-cart_foot { border-top: 0.0625rem solid var(--_theme---border); padding: var(--_spacing---space--5) var(--_spacing---space--6); display: flex; flex-direction: column; gap: var(--_spacing---space--4); }
  .op-cart_subtotal { display: flex; align-items: center; justify-content: space-between; font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.8rem; }
  .op-cart_checkout { width: 100%; font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.8rem; color: #fff; background-color: var(--swatch--brand-300, #b0b094); border: 0; border-radius: 2rem; padding: 1rem 2rem; cursor: pointer; transition: background-color 250ms; }
  .op-cart_checkout:hover { background-color: var(--swatch--brand-500, #5f604e); }
  .op-cart_view { text-align: center; font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.74rem; color: currentColor; text-decoration: none; opacity: 0.7; }
  .op-cart_view:hover { opacity: 1; }
  .op-cart_continue { font-family: var(--font-label); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.78rem; color: var(--_theme---text); background: transparent; border: 0.0625rem solid var(--_theme---text); border-radius: 2rem; padding: 0.85rem 1.8rem; cursor: pointer; }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart drawer On Paper",
  "settings": [
    { "type": "text", "id": "title", "label": "Título", "default": "Carrito" },
    { "type": "text", "id": "subtotal_label", "label": "Subtotal", "default": "Subtotal" },
    { "type": "text", "id": "checkout_label", "label": "Botón checkout", "default": "Finalizar compra" },
    { "type": "text", "id": "view_label", "label": "Ver carrito", "default": "Ver carrito" },
    { "type": "text", "id": "remove_label", "label": "Quitar", "default": "Quitar" },
    { "type": "text", "id": "empty_text", "label": "Texto vacío", "default": "Tu carrito está vacío." },
    { "type": "text", "id": "error_text", "label": "Mensaje de error", "default": "No se pudo actualizar el carrito. Inténtalo de nuevo." },
    { "type": "text", "id": "continue_label", "label": "Seguir comprando", "default": "Seguir comprando" }
  ]
}
{% endschema %}
