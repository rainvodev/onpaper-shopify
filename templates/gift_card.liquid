{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Marca On Paper (tipografías + tokens, igual que theme.liquid) %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Source+Serif+Pro:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
    {{ 'lumos.css' | asset_url | stylesheet_tag }}
    {{ 'brand.css' | asset_url | stylesheet_tag }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 96 }}">
    {%- endif -%}

    {% style %}
      body { background-color: var(--swatch--light-200, #f5f5ef); color: var(--swatch--brand-500, #5f604e); }
      main { text-align: center; min-height: 100svh; display: flex; align-items: center; justify-content: center; padding: 2rem; }
      main img { display: unset; max-width: 100%; }
      main .shopify-section { display: flex; flex-direction: column; gap: 0.9rem; max-width: 26rem; }
      main h1 { font-family: var(--_typography---font--primary-family, serif); font-style: italic; font-weight: 400; font-size: clamp(2rem, 6vw, 2.8rem); color: var(--swatch--brand-300, #b0b094); margin: 0; }
      main h2 { font-family: var(--font-label, inherit); text-transform: uppercase; letter-spacing: 0.16em; font-size: 0.8rem; font-weight: 400; margin: 0; opacity: 0.8; }
      main p { margin: 0; }
    {% endstyle %}

    {{ content_for_header }}
  </head>

  <body>
    <main>
      <div class="shopify-section">
        <h1>{{ gift_card.balance | money }}</h1>

        {% if gift_card.enabled == false or gift_card.expired %}
          <p>{{ 'gift_card.expired' | t }}</p>
        {% endif %}

        {% if gift_card.expires_on %}
          {% assign expires_on = gift_card.expires_on | date: '%B %e, %Y' %}
          <p>
            {{ 'gift_card.expires_on' | t: expires_on: expires_on }}
          </p>
        {% endif %}

        <p>
          {% if settings.logo %}
            {{ settings.logo | image_url: width: 300 | image_tag: alt: shop.name }}
          {% else %}
            <img
              src="{{ 'gift-card/card.svg' | shopify_asset_url }}"
              alt="{{ 'gift_card.card' | t }}"
              width="300"
              height="200"
            >
          {% endif %}
        </p>

        <h2>{{ shop.name }}</h2>
        <p>{{ 'gift_card.use_at_checkout' | t }}</p>
        <p>{{ gift_card.code | format_code }}</p>

        {% if gift_card.pass_url %}
          <a href="{{ gift_card.pass_url }}">
            <img
              src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
              alt="{{ 'gift_card.add_to_apple_wallet' | t }}"
              width="200"
              height="60"
            >
          </a>
        {% endif %}
      </div>
    </main>
  </body>
</html>
